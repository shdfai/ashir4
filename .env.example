# ─── XT.com API ──────────────────────────────────────────────────────────
XT_API_KEY=your_xt_api_key_here
XT_SECRET_KEY=your_xt_secret_key_here

# ─── Trading Mode ────────────────────────────────────────────────────────
# paper = simulated trading with virtual balance (real market prices)
# live  = real trading on XT.com with real money
TRADING_MODE=paper
PAPER_STARTING_BALANCE=200.0

# ─── Telegram ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── Database (Railway provides this automatically when you add Postgres) ─
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot

# ─── Trading Parameters ─────────────────────────────────────────────────
MAX_OPEN_TRADES=5
DEFAULT_LEVERAGE=10
MAX_LEVERAGE=20
MIN_LEVERAGE=3
RISK_PER_TRADE=1.5
MAX_DAILY_LOSS=5.0
MIN_BALANCE_USDT=20.0
PRIMARY_TIMEFRAME=15m
MAX_SYMBOLS_TRADED=8
SYMBOL_SELECTION=auto_volume

# ─── AI Config ───────────────────────────────────────────────────────────
AI_RETRAIN_INTERVAL_HOURS=24
AI_MIN_CONFIDENCE=0.60

# ─── Dashboard ───────────────────────────────────────────────────────────
DASHBOARD_SECRET_KEY=change_this_to_random_string
PORT=8000

# ─── App ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Tehran
